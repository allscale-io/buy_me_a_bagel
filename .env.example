# Allscale Commerce API credentials
# Get yours at https://allscale.io

ALLSCALE_API_KEY=your_api_key_here
ALLSCALE_API_SECRET=your_api_secret_here

# "https://openapi-sandbox.allscale.io" for testing
# "https://openapi.allscale.io" for production
ALLSCALE_BASE_URL=https://openapi-sandbox.allscale.io

# Fiat currency for pricing (USD, EUR, GBP, CAD, AUD, JPY, CNY, SGD, HKD)
ALLSCALE_CURRENCY=USD
